import tkinter as tk
import paho.mqtt.client as mqtt

# ===== MQTT Configuration =====
MQTT_BROKER = "broker.emqx.io" 
# IMPORTANT: This topic must exactly match the one used in your Arduino code
TOPIC = "SIT210/crafting/alert/YOUR_IDENTIFIER"

# ===== GUI Update Functions =====
def show_reminder(message):
    """Updates the GUI label and brings the window to the front."""
    alert_label.config(text=f"{message}\nPlease Rest Your Eyes.", fg="blue", font=("Arial", 16, "bold"))

    # Bring the window to the front of the screen
    root.attributes("-topmost", True)

def dismiss_reminder():
    """Resets the GUI to the default monitoring state."""
    alert_label.config(text="Status: Monitoring Environment...", fg="gray", font=("Arial", 12)
)
    # Allow the window to go to the background again
    root.attributes("-topmost", False)

# ===== MQTT Callbacks =====
def on_connect(client, userdata, flags, rc):
    print(f"Connected to MQTT Broker with result code {rc}")
    # Subscribe to the topic upon successful connection
    client.subscribe(TOPIC)
    print(f"Subscribed to topic: {TOPIC}")

def on_message(client, userdata, msg):
    payload = msg.payload.decode()
    print(f"Message received: {payload}")
    # Safely update the Tkinter GUI from the MQTT background thread
    root.after(0, show_reminder, payload)

def close_app():
    """Cleanly disconnects MQTT and closes the application."""
    print("Closing application...")
    client.loop_stop()
    root.destroy()

# ===== Application & GUI Setup =====
root = tk.Tk()
root.title("Smart Crafting Monitor")
root.geometry("400x250")

# Header Label
tk.Label(root, text="Smart Crafting Monitor", font=("Arial", 16, "bold")).pack(pady=20)

# Dynamic Alert Label
alert_label = tk.Label(root, text="Status: Monitoring Environment...", font=("Arial", 12))
alert_label.pack(pady=20)

# Control Buttons
tk.Button(root, text="Dismiss Reminder", command=dismiss_reminder, font=("Arial", 12)).pack(pady=5)

tk.Button(root, text="Exit", command=close_app, bg="red", fg="white", font=("Arial", 12)).pack(pady=10)

# ===== Initialize & Start MQTT Client =====
client = mqtt.Client()
client.on_connect = on_connect
client.on_message = on_message

try:
    print("Connecting to broker...")
    client.connect(MQTT_BROKER, 1883, 60)
    # Start the network loop in a background thread
    client.loop_start() 
except Exception as e:
    print(f"Failed to connect to MQTT broker: {e}")

# Handle the window close button (X)
root.protocol("WM_DELETE_WINDOW", close_app)

# Keep the GUI window
root.mainloop()
