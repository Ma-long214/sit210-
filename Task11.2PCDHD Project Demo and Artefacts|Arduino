// Note: For security and uniqueness, replace the WiFi credentials 
// and the "YOUR_IDENTIFIER" in the MQTT topic before running the project.

#include <WiFiNINA.h>
#include <PubSubClient.h>
#include <Wire.h>
#include <BH1750.h>

// ===== WiFi & MQTT Credentials =====
char ssid[] = "YOUR_WIFI_NAME";
char pass[] = "YOUR_WIFI_PASSWORD";
const char* mqtt_server = "broker.emqx.io"; // Using the public MQTT broker

WiFiClient wifiClient;
PubSubClient mqttClient(wifiClient);
BH1750 lightMeter;

// ===== Pin Definitions & Constants =====
const int pirPin = 2;
const int ledPin = 5;
const float DARKNESS_THRESHOLD = 50.0;
// 30 seconds for testing purposes. Change to a higher value for real-world use.
const unsigned long WORK_TIME_LIMIT = 30000; 

// ===== State Variables & ISR Flags =====
volatile bool pirEventTriggered = false;
bool motionActive = false;
bool isWorking = false;
bool reminderSent = false;
unsigned long workStartTime = 0;

void setup() {
  Serial.begin(9600);
  while (!Serial);

  // Initialize I2C and BH1750 Sensor
  Wire.begin();
  if (lightMeter.begin()) {
    Serial.println("BH1750 Initialized Successfully.");
  }
  else {
    Serial.println("Error initializing BH1750.");
  }

  // Configure Pins
  pinMode(pirPin, INPUT_PULLDOWN);
  pinMode(ledPin, OUTPUT);

  // Attach Hardware Interrupt for the PIR Motion Sensor
  attachInterrupt(digitalPinToInterrupt(pirPin), pirISR, CHANGE);

  // Initialize Network & MQTT Communication
  connectToWiFi();
  mqttClient.setServer(mqtt_server, 1883);
}

void loop() {
  if (!mqttClient.connected()) {
    reconnectMQTT();
  }
  mqttClient.loop();

  // ===== 1. Trigger Processing (Only record the "Change" in motion) =====
  if (pirEventTriggered) {
    int pirState = digitalRead(pirPin);

    if (pirState == HIGH) {
      motionActive = true; // Note down: "Someone is here!"
      Serial.println("Motion detected.");
    }
    else {
      motionActive = false; // Note down: "The person left!"
      digitalWrite(ledPin, LOW); // Ensure LED is turned off
      isWorking = false;
      Serial.println("Motion stopped. Work session paused.");
    }
    pirEventTriggered = false; // Reset the interrupt flag
  }

  // ===== 2. State Monitoring (Continuously check light WHILE someone is present) =====
  if (motionActive) {
    float lux = lightMeter.readLightLevel();
    
    if (lux < DARKNESS_THRESHOLD) {
      // If someone is present AND it is dark
      digitalWrite(ledPin, HIGH); // Turn on the LED
      
      if (!isWorking) {
        isWorking = true;
        workStartTime = millis(); // Start the timer
        reminderSent = false;
        Serial.println("Dark environment detected. Work session started.");
      }
    }
    else {
      // If someone is present BUT it is bright
      digitalWrite(ledPin, LOW); // Turn off the LED because the room is bright enough
      
      if (isWorking) {
        isWorking = false; // Pause the timer if it gets bright again
        Serial.println("Room is bright enough. LED off.");
      }
    }
  }

  // ===== 3. Timer and Alert Sending (Unchanged) =====
  if (isWorking && !reminderSent) {
    if (millis() - workStartTime >= WORK_TIME_LIMIT) {
      Serial.println("Work time limit reached! Sending MQTT reminder.");
      
      // IMPORTANT: Change "YOUR_IDENTIFIER" to your student ID or name
      mqttClient.publish("SIT210/crafting/alert/YOUR_IDENTIFIER", "Time for a Break!");
      
      reminderSent = true;
    }
  }
}

// ===== Hardware Interrupt Service Routine (ISR) =====
void pirISR() {
  pirEventTriggered = true; 
}

// ===== Helper Functions for Networking =====
void connectToWiFi() {
  Serial.print("Connecting to WiFi...");
  while (WiFi.status() != WL_CONNECTED) {
    WiFi.begin(ssid, pass);
    Serial.print(".");
    delay(5000);
  }
  Serial.println("\nWiFi Connected Successfully.");
}

void reconnectMQTT() {
  while (!mqttClient.connected()) {
    Serial.print("Attempting MQTT connection...");
    // Create a random client ID
    String clientId = "ArduinoClient-";
    clientId += String(random(0xffff), HEX);
    
    if (mqttClient.connect(clientId.c_str())) {
      Serial.println("Connected to MQTT Broker.");
    }
    else {
      Serial.print("Failed, rc=");
      Serial.print(mqttClient.state());
      Serial.println(" Trying again in 5 seconds.");
      delay(5000);
    }
  }
}
